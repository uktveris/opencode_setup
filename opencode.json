{
    "$schema": "https://opencode.ai/config.json",
    "permission": {
        "bash": "ask",
        "task": "ask",
        "*.env.example": "deny",
        "*.env.local": "deny",
        "*.env.dev": "deny",
        "git *": "deny"
    },
    "agent": {
        "review": {
            "temperature": 0.5,
            "prompt": "{file:./agents/review.md}",
            "tools": {
                "write": false,
                "bash": false
            },
            "permission": {
                "edit": "deny"
            }
        }
    }
}
